# Airflow configuration
AIRFLOW_IMAGE_NAME=igh-airflow:latest

# Redis password (for CeleryExecutor)
REDIS_PASSWORD=redispass
# Set to your user ID on Linux: echo "AIRFLOW_UID=$(id -u)" >> .env
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Security keys (generate with commands below)
# uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=
# API secret key for JWT signing between services (REQUIRED for Airflow 3.x)
# Generate with: uv run python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__API__SECRET_KEY=

# Data paths
BRONZE_DB_PATH=/opt/airflow/data/bronze/dataverse.db
SILVER_DB_PATH=/opt/airflow/data/silver/igh_silver.db
GOLD_DB_PATH=/opt/airflow/data/gold/star_schema.db
# Remote deployment (SCP to dashboard server)
# Defaults to "local" in dev docker-compose.yml (skips deployment)
# DEPLOY_TARGET_HOST=

# Dataverse API credentials
DATAVERSE_API_URL=https://your-org.crm.dynamics.com
DATAVERSE_CLIENT_ID=your-client-id
DATAVERSE_CLIENT_SECRET=your-client-secret
DATAVERSE_SCOPE=https://your-org.crm.dynamics.com/.default
