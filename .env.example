# Airflow configuration
# Set to your user ID on Linux: echo "AIRFLOW_UID=$(id -u)" >> .env
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Security keys (generate with commands below)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=
# python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=

# Additional pip packages (optional)
_PIP_ADDITIONAL_REQUIREMENTS=

# Slack webhook for alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Data paths
BRONZE_DB_PATH=/opt/airflow/data/bronze/dataverse.db
SILVER_DB_PATH=/opt/airflow/data/silver/igh_silver.db
PRODUCTION_DB_PATH=/opt/airflow/data/production/igh.db
